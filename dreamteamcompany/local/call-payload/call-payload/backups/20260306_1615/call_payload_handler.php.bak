<?php
declare(strict_types=1);

/**
 * Minimal webhook handler:
 * - Accepts POST JSON with: CALL_ID (string) and RAW_PAYLOAD_JSON (string|object|array)
 * - Persists payload to storage/call_payloads/*.json
 * - Returns JSON response
 *
 * Run locally:
 *   php -S 127.0.0.1:8080 call_payload_handler.php
 */

header('Content-Type: application/json; charset=utf-8');

use App\Bitrix\BitrixBootstrap;
use App\Bitrix\Iblock122ScoreWriter;
use App\Parser\MarkdownScoreParser;

$GLOBALS['score_parser_write_logs'] = true;
$GLOBALS['score_parser_webhook_debug_log'] = null;
$GLOBALS['score_parser_writer_log'] = null;
$GLOBALS['score_parser_service_timezone'] = 'Europe/Moscow';

function ensureDir(string $path): void
{
    if (is_dir($path)) {
        return;
    }

    @mkdir($path, 0775, true);
}

/**
 * Safe include for optional processing dependencies.
 */
function tryIncludeOnce(string $path): bool
{
    if (!is_file($path)) {
        return false;
    }

    try {
        include_once $path;
    } catch (Throwable $e) {
        appendEmergencyLog(
            $GLOBALS['score_parser_webhook_debug_log'] ?? null,
            'INCLUDE_ERROR path=' . $path . ' message=' . $e->getMessage()
        );
        appendEmergencyLog(
            $GLOBALS['score_parser_writer_log'] ?? null,
            'INCLUDE_ERROR path=' . $path . ' message=' . $e->getMessage()
        );
        return false;
    }

    return true;
}

function respond(int $status, array $body): never
{
    http_response_code($status);
    echo json_encode(
        $body,
        JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT
    );
    exit;
}

/**
 * @param mixed $rawPayloadJson
 * @param mixed $rawPayloadParsed
 */
function resolveParserInput($rawPayloadJson, $rawPayloadParsed): string
{
    if (is_string($rawPayloadJson) && trim($rawPayloadJson) !== '') {
        return $rawPayloadJson;
    }

    if (is_array($rawPayloadParsed)) {
        $encoded = json_encode(
            $rawPayloadParsed,
            JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT
        );

        if (is_string($encoded) && $encoded !== '') {
            return $encoded;
        }
    }

    if (is_array($rawPayloadJson)) {
        $encoded = json_encode(
            $rawPayloadJson,
            JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT
        );

        if (is_string($encoded) && $encoded !== '') {
            return $encoded;
        }
    }

    return '';
}

/**
 * @param mixed $source
 * @return array<string, mixed>
 */
function normalizeToArray($source): array
{
    if (is_array($source)) {
        return $source;
    }
    if (is_object($source)) {
        try {
            $encoded = json_encode($source, JSON_THROW_ON_ERROR);
            $decoded = json_decode((string) $encoded, true, 512, JSON_THROW_ON_ERROR);
            return is_array($decoded) ? $decoded : [];
        } catch (Throwable $e) {
            return [];
        }
    }
    return [];
}

/**
 * @param mixed $source
 * @param list<string> $keys
 * @return mixed|null
 */
function findValueByKeysRecursive($source, array $keys)
{
    $normalizedWanted = [];
    foreach ($keys as $key) {
        $normalizedWanted[] = strtolower(trim($key));
    }

    $stack = [normalizeToArray($source)];
    while ($stack !== []) {
        $current = array_pop($stack);
        if (!is_array($current)) {
            continue;
        }

        foreach ($current as $k => $v) {
            if (is_string($k)) {
                $normalizedKey = strtolower(trim($k));
                if (in_array($normalizedKey, $normalizedWanted, true)) {
                    return $v;
                }
            }

            if (is_array($v)) {
                $stack[] = $v;
            } elseif (is_object($v)) {
                $stack[] = normalizeToArray($v);
            }
        }
    }

    return null;
}

/**
 * @param mixed $value
 */
function toStringOrNull($value): ?string
{
    if (is_string($value)) {
        $trimmed = trim($value);
        return $trimmed === '' ? null : $trimmed;
    }
    if (is_int($value) || is_float($value)) {
        return (string) $value;
    }
    return null;
}

/**
 * @param mixed $value
 */
function toNumericStringOrNull($value): ?string
{
    if (is_int($value) || is_float($value)) {
        return (string) $value;
    }

    if (!is_string($value)) {
        return null;
    }

    $normalized = str_replace(',', '.', trim($value));
    if ($normalized === '') {
        return null;
    }

    if (preg_match('/^-?\d+(?:\.\d+)?$/', $normalized) !== 1) {
        return null;
    }

    return $normalized;
}

/**
 * @param array<string, mixed> $rawPayloadParsed
 * @param array<string, mixed> $requestPayload
 * @return array<string, int|float|string>
 */
function extractSupplementalMetadata(array $rawPayloadParsed, array $requestPayload, string $timezone): array
{
    $source = [
        'raw_payload_parsed' => $rawPayloadParsed,
        'request_payload' => $requestPayload,
    ];

    $metadata = [];

    $stringFieldMap = [
        'NAME' => ['NAME', 'TITLE'],
        'PORTAL_NUMBER' => ['PORTAL_NUMBER', 'PORTAL_NUMBER_ID', 'PORTAL'],
        'CRM_ENTITY_TYPE' => ['CRM_ENTITY_TYPE', 'ENTITY_TYPE', 'CRM_TYPE'],
    ];
    foreach ($stringFieldMap as $targetField => $keys) {
        $value = toStringOrNull(findValueByKeysRecursive($source, $keys));
        if ($value !== null) {
            $metadata[$targetField] = $value;
        }
    }

    $numericFieldMap = [
        'PHONE_NUMBER' => ['PHONE_NUMBER', 'PHONE', 'CLIENT_PHONE', 'PHONE_DIGITS'],
        'CRM_ENTITY_ID' => ['CRM_ENTITY_ID', 'ENTITY_ID'],
        'CRM_ACTIVITY_ID' => ['CRM_ACTIVITY_ID', 'ACTIVITY_ID'],
        'PORTAL_USER_ID' => ['PORTAL_USER_ID', 'USER_ID', 'RESPONSIBLE_ID'],
        'CALL_DURATION' => ['CALL_DURATION', 'DURATION', 'DURATION_SEC'],
        'CALL_TYPE' => ['CALL_TYPE', 'TYPE', 'CALL_DIRECTION'],
    ];
    foreach ($numericFieldMap as $targetField => $keys) {
        $rawValue = findValueByKeysRecursive($source, $keys);
        if ($targetField === 'PHONE_NUMBER' && is_string($rawValue)) {
            $digitsOnly = preg_replace('/\D+/', '', $rawValue);
            if (is_string($digitsOnly) && $digitsOnly !== '') {
                $metadata[$targetField] = $digitsOnly;
                continue;
            }
        }

        $value = toNumericStringOrNull($rawValue);
        if ($value !== null) {
            $metadata[$targetField] = $value;
        }
    }

    $callStartRaw = findValueByKeysRecursive($source, ['CALL_START_DATE', 'CALL_START', 'START_DATE', 'DATE_START']);
    $callStartString = toStringOrNull($callStartRaw);
    if ($callStartString !== null) {
        $converted = toBitrixDateTime($callStartString, $timezone);
        if ($converted !== null) {
            $metadata['CALL_START_DATE'] = $converted;
        }
    }

    return $metadata;
}

function appendIntegrationLog(string $logFilePath, string $message, bool $force = false): void
{
    $timezone = (string) ($GLOBALS['score_parser_service_timezone'] ?? 'Europe/Moscow');
    try {
        $lineTimestamp = (new DateTimeImmutable('now', new DateTimeZone($timezone)))->format('c');
    } catch (Throwable $e) {
        $lineTimestamp = gmdate('c');
    }

    if ($force) {
        $line = '[' . $lineTimestamp . '] ' . $message . PHP_EOL;
        @file_put_contents($logFilePath, $line, FILE_APPEND | LOCK_EX);
        return;
    }

    $writeLogs = $GLOBALS['score_parser_write_logs'] ?? true;
    if ($writeLogs !== true) {
        return;
    }

    $line = '[' . $lineTimestamp . '] ' . $message . PHP_EOL;
    @file_put_contents($logFilePath, $line, FILE_APPEND | LOCK_EX);
}

function appendEmergencyLog(?string $logFilePath, string $message): void
{
    if (!is_string($logFilePath) || $logFilePath === '') {
        return;
    }

    $timezone = (string) ($GLOBALS['score_parser_service_timezone'] ?? 'Europe/Moscow');
    try {
        $lineTimestamp = (new DateTimeImmutable('now', new DateTimeZone($timezone)))->format('c');
    } catch (Throwable $e) {
        $lineTimestamp = gmdate('c');
    }

    $line = '[' . $lineTimestamp . '] ' . $message . PHP_EOL;
    @file_put_contents($logFilePath, $line, FILE_APPEND | LOCK_EX);
}

function toBitrixDateTime(string $value, string $timezone = 'Europe/Moscow'): ?string
{
    try {
        // Primary path: parse timestamp with offset (or UTC default) and convert.
        $targetTz = new DateTimeZone(trim($timezone) !== '' ? $timezone : 'Europe/Moscow');
        $dt = new DateTimeImmutable($value, new DateTimeZone('UTC'));
        $dt = $dt->setTimezone($targetTz);
        return $dt->format('d.m.Y H:i:s');
    } catch (Throwable $e) {
    }

    $timestamp = strtotime($value);
    if ($timestamp === false) {
        return null;
    }

    try {
        $targetTz = new DateTimeZone(trim($timezone) !== '' ? $timezone : 'Europe/Moscow');
        $dt = (new DateTimeImmutable('@' . (string) $timestamp))->setTimezone($targetTz);
        return $dt->format('d.m.Y H:i:s');
    } catch (Throwable $e) {
        return null;
    }
}

$baseStorageDir = __DIR__ . DIRECTORY_SEPARATOR . 'storage';
$payloadStorageDir = $baseStorageDir . DIRECTORY_SEPARATOR . 'call_payloads';
ensureDir($baseStorageDir);
ensureDir($payloadStorageDir);
$webhookDebugLog = $baseStorageDir . DIRECTORY_SEPARATOR . 'webhook_debug.log';
$GLOBALS['score_parser_webhook_debug_log'] = $webhookDebugLog;

register_shutdown_function(static function (): void {
    $lastError = error_get_last();
    if (!is_array($lastError)) {
        return;
    }

    $fatalTypes = [E_ERROR, E_PARSE, E_CORE_ERROR, E_COMPILE_ERROR, E_USER_ERROR];
    if (!in_array((int) ($lastError['type'] ?? 0), $fatalTypes, true)) {
        return;
    }

    $message = sprintf(
        'FATAL type=%s file=%s line=%s message=%s',
        (string) ($lastError['type'] ?? ''),
        (string) ($lastError['file'] ?? ''),
        (string) ($lastError['line'] ?? ''),
        (string) ($lastError['message'] ?? '')
    );

    appendEmergencyLog($GLOBALS['score_parser_webhook_debug_log'] ?? null, $message);
    appendEmergencyLog($GLOBALS['score_parser_writer_log'] ?? null, $message);
});

$requestMethod = (string) ($_SERVER['REQUEST_METHOD'] ?? '');
$requestContentType = (string) ($_SERVER['CONTENT_TYPE'] ?? '');
appendIntegrationLog(
    $webhookDebugLog,
    sprintf(
        'INCOMING method=%s content_type=%s remote_ip=%s ua=%s',
        $requestMethod,
        $requestContentType,
        (string) ($_SERVER['REMOTE_ADDR'] ?? ''),
        (string) ($_SERVER['HTTP_USER_AGENT'] ?? '')
    ),
    true
);

if ($requestMethod !== 'POST') {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=method_not_allowed');
    respond(405, [
        'ok' => false,
        'error' => 'Method Not Allowed. Use POST.',
    ]);
}

$rawBody = file_get_contents('php://input');
if ($rawBody === false || trim($rawBody) === '') {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=empty_request_body');
    respond(400, [
        'ok' => false,
        'error' => 'Empty request body.',
    ]);
}

try {
    /** @var array<string, mixed> $payload */
    $payload = json_decode($rawBody, true, 512, JSON_THROW_ON_ERROR);
} catch (Throwable $e) {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=invalid_json_body details=' . $e->getMessage());
    respond(400, [
        'ok' => false,
        'error' => 'Invalid JSON body.',
        'details' => $e->getMessage(),
    ]);
}

$callId = $payload['CALL_ID'] ?? null;
if (!is_string($callId) || trim($callId) === '') {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=missing_call_id');
    respond(422, [
        'ok' => false,
        'error' => 'CALL_ID is required and must be a non-empty string.',
    ]);
}

$rawPayloadJson = $payload['RAW_PAYLOAD_JSON'] ?? null;
if ($rawPayloadJson === null) {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=missing_raw_payload_json');
    respond(422, [
        'ok' => false,
        'error' => 'RAW_PAYLOAD_JSON is required.',
    ]);
}

// RAW_PAYLOAD_JSON can be:
// - string: a JSON string (we'll try to decode it)
// - array/object: already decoded payload (we'll keep it as-is)
$rawPayloadNormalized = $rawPayloadJson;
$rawPayloadParsed = null;
$rawPayloadParseError = null;

if (is_string($rawPayloadJson)) {
    $rawPayloadNormalized = $rawPayloadJson;
    $trimmed = trim($rawPayloadJson);
    if ($trimmed !== '') {
        try {
            $rawPayloadParsed = json_decode($rawPayloadJson, true, 512, JSON_THROW_ON_ERROR);
        } catch (Throwable $e) {
            $rawPayloadParseError = $e->getMessage();
        }
    }
} elseif (is_array($rawPayloadJson)) {
    $rawPayloadParsed = $rawPayloadJson;
} elseif (is_object($rawPayloadJson)) {
    /** @var array<string, mixed> $asArray */
    $asArray = json_decode(json_encode($rawPayloadJson, JSON_THROW_ON_ERROR), true, 512, JSON_THROW_ON_ERROR);
    $rawPayloadParsed = $asArray;
} else {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=raw_payload_wrong_type got=' . gettype($rawPayloadJson));
    respond(422, [
        'ok' => false,
        'error' => 'RAW_PAYLOAD_JSON must be a string or JSON object/array.',
        'got_type' => gettype($rawPayloadJson),
    ]);
}

$storageDir = $payloadStorageDir;
if (!is_dir($storageDir)) {
    if (!mkdir($storageDir, 0775, true) && !is_dir($storageDir)) {
        appendIntegrationLog($webhookDebugLog, 'REJECT reason=storage_dir_create_failed path=' . $storageDir);
        respond(500, [
            'ok' => false,
            'error' => 'Failed to create storage directory.',
            'storageDir' => $storageDir,
        ]);
    }
}

$safeCallId = preg_replace('/[^A-Za-z0-9_.-]+/', '_', $callId) ?? 'call';
$fileTimestampTimezone = (string) ($GLOBALS['score_parser_service_timezone'] ?? 'Europe/Moscow');
try {
    $ts = (new DateTimeImmutable('now', new DateTimeZone($fileTimestampTimezone)))->format('Ymd_His');
} catch (Throwable $e) {
    $ts = gmdate('Ymd_His');
}
$rnd = bin2hex(random_bytes(4));
$fileName = $safeCallId . '_' . $ts . '_' . $rnd . '.json';
$filePath = $storageDir . DIRECTORY_SEPARATOR . $fileName;

$toStore = [
    'received_at' => gmdate('c'),
    'call_id' => $callId,
    'remote_ip' => $_SERVER['REMOTE_ADDR'] ?? null,
    'user_agent' => $_SERVER['HTTP_USER_AGENT'] ?? null,
    'raw_payload_json' => $rawPayloadNormalized,
    'raw_payload_parsed' => $rawPayloadParsed,
    'raw_payload_parse_error' => $rawPayloadParseError,
    'original_request_body' => $payload,
];

$json = json_encode(
    $toStore,
    JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT
);

if ($json === false) {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=json_encode_failed_before_file_write');
    respond(500, [
        'ok' => false,
        'error' => 'Failed to encode JSON for storage.',
    ]);
}

$bytes = @file_put_contents($filePath, $json . "\n", LOCK_EX);
if ($bytes === false) {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=file_write_failed path=' . $filePath);
    respond(500, [
        'ok' => false,
        'error' => 'Failed to write file.',
        'filePath' => $filePath,
    ]);
}

$configPath = __DIR__ . DIRECTORY_SEPARATOR . 'config' . DIRECTORY_SEPARATOR . 'score_parser.php';
if (!is_file($configPath)) {
    appendIntegrationLog($webhookDebugLog, 'REJECT reason=missing_config path=' . $configPath);
    respond(500, [
        'ok' => false,
        'error' => 'Score parser config is missing.',
        'configPath' => $configPath,
    ]);
}

/** @var array<string, mixed> $scoreConfig */
$scoreConfig = require $configPath;
$GLOBALS['score_parser_write_logs'] = (bool) ($scoreConfig['write_logs'] ?? true);
$GLOBALS['score_parser_service_timezone'] = (string) ($scoreConfig['service_timezone'] ?? $scoreConfig['call_datetime_timezone'] ?? 'Europe/Moscow');

$integrationLogPath = $storageDir . DIRECTORY_SEPARATOR . 'score_writer.log';
$GLOBALS['score_parser_writer_log'] = $integrationLogPath;
$parserInput = resolveParserInput($rawPayloadNormalized, $rawPayloadParsed);
if (is_string($rawPayloadNormalized)) {
    $statusLineMatch = [];
    if (preg_match('/Статус\s*записи\s*:\s*([^\r\n]+)/ui', $rawPayloadNormalized, $statusLineMatch) === 1) {
        appendIntegrationLog(
            $integrationLogPath,
            sprintf(
                'CALL_ID=%s FILE=%s IS_BOOKED_STAGE=RAW_INPUT status_line=%s',
                $callId,
                $fileName,
                trim((string) $statusLineMatch[1])
            ),
            true
        );
    } else {
        appendIntegrationLog(
            $integrationLogPath,
            sprintf('CALL_ID=%s FILE=%s IS_BOOKED_STAGE=RAW_INPUT status_line=NOT_FOUND', $callId, $fileName),
            true
        );
    }
}
appendIntegrationLog(
    $integrationLogPath,
    sprintf('CALL_ID=%s FILE=%s PROCESS_START', $callId, $fileName),
    true
);
appendIntegrationLog(
    $integrationLogPath,
    sprintf('CALL_ID=%s FILE=%s STAGE=AFTER_CONFIG_LOAD', $callId, $fileName),
    true
);
$processingDependenciesLoaded = true;
$deps = [
    __DIR__ . '/src/Contracts/ScoreParserInterface.php',
    __DIR__ . '/src/Contracts/IblockScoreWriterInterface.php',
    __DIR__ . '/src/DTO/ScorePayloadDTO.php',
    __DIR__ . '/src/Parser/MarkdownScoreParser.php',
    __DIR__ . '/src/Bitrix/BitrixBootstrap.php',
    __DIR__ . '/src/Bitrix/Iblock122ScoreWriter.php',
];
foreach ($deps as $depPath) {
    if (!tryIncludeOnce($depPath)) {
        $processingDependenciesLoaded = false;
        appendIntegrationLog($webhookDebugLog, 'WARN reason=missing_dependency path=' . $depPath, true);
        appendIntegrationLog(
            $integrationLogPath,
            sprintf('CALL_ID=%s FILE=%s DEP_MISSING=%s', $callId, $fileName, $depPath),
            true
        );
    }
}
appendIntegrationLog(
    $integrationLogPath,
    sprintf(
        'CALL_ID=%s FILE=%s STAGE=DEPS_LOADED status=%s',
        $callId,
        $fileName,
        $processingDependenciesLoaded ? 'Y' : 'N'
    ),
    true
);

$bitrixResult = null;
$bitrixError = null;
$failFast = (bool) ($scoreConfig['fail_fast_on_bitrix_error'] ?? false);
$verboseResponse = isset($_GET['verbose']) && $_GET['verbose'] === '1';
$deleteProcessedFiles = (bool) ($scoreConfig['delete_processed_files'] ?? false);
$scorePayload = null;

if (
    $processingDependenciesLoaded
    && class_exists(MarkdownScoreParser::class)
) {
    try {
        $parser = new MarkdownScoreParser((int) ($scoreConfig['default_base_score'] ?? 27));
        $scorePayload = $parser->parse($parserInput);
        appendIntegrationLog(
            $integrationLogPath,
            sprintf(
                'CALL_ID=%s FILE=%s IS_BOOKED_STAGE=PARSED parsed_value=%s',
                $callId,
                $fileName,
                (string) ($scorePayload->isBookedValue() ?? 'NULL')
            ),
            true
        );
        if (
            ((bool) ($scoreConfig['fill_call_datetime_from_received_at'] ?? true))
        ) {
            $preferReceivedAt = (bool) ($scoreConfig['call_datetime_prefer_received_at'] ?? true);
            $timezone = (string) ($scoreConfig['call_datetime_timezone'] ?? 'Europe/Moscow');
            $hasCallDateTime = $scorePayload->callDateTime() !== null && $scorePayload->callDateTime() !== '';
            if ($preferReceivedAt || !$hasCallDateTime) {
                $fallbackCallDateTime = toBitrixDateTime((string) ($toStore['received_at'] ?? ''), $timezone);
            } else {
                $fallbackCallDateTime = null;
            }
            if ($fallbackCallDateTime !== null) {
                $scorePayload = $scorePayload->withCallDateTime($fallbackCallDateTime);
            }
        }
        $supplementalMetadata = extractSupplementalMetadata(
            is_array($rawPayloadParsed) ? $rawPayloadParsed : [],
            $payload,
            (string) ($scoreConfig['call_datetime_timezone'] ?? 'Europe/Moscow')
        );
        if ($supplementalMetadata !== []) {
            $scorePayload = $scorePayload->withMetadata($supplementalMetadata);
        }
    } catch (Throwable $e) {
        $bitrixError = 'Parser failed: ' . $e->getMessage();
        appendIntegrationLog(
            $integrationLogPath,
            sprintf('CALL_ID=%s FILE=%s PARSER_ERROR=%s', $callId, $fileName, $bitrixError),
            true
        );
        appendIntegrationLog(
            $webhookDebugLog,
            sprintf('ERROR reason=parser_failed call_id=%s details=%s', $callId, $e->getMessage()),
            true
        );
    }
} else {
    appendIntegrationLog($webhookDebugLog, 'WARN reason=processing_dependencies_not_loaded mode=file_only', true);
    appendIntegrationLog(
        $integrationLogPath,
        sprintf('CALL_ID=%s FILE=%s STAGE=PARSER_SKIPPED reason=deps_not_loaded', $callId, $fileName),
        true
    );
}

try {
    if (
        $scorePayload !== null
        && class_exists(BitrixBootstrap::class)
        && class_exists(Iblock122ScoreWriter::class)
    ) {
        $bootstrap = new BitrixBootstrap(
            isset($scoreConfig['bitrix_prolog_before_path']) && is_string($scoreConfig['bitrix_prolog_before_path'])
                ? $scoreConfig['bitrix_prolog_before_path']
                : null
        );
        $writerConfig = $scoreConfig;
        $writerConfig['runtime_log_path'] = $integrationLogPath;
        $writer = new Iblock122ScoreWriter($bootstrap, $writerConfig);
        appendIntegrationLog(
            $integrationLogPath,
            sprintf('CALL_ID=%s FILE=%s STAGE=BEFORE_BITRIX_WRITE', $callId, $fileName),
            true
        );
        appendIntegrationLog(
            $integrationLogPath,
            sprintf(
                'CALL_ID=%s FILE=%s IS_BOOKED_STAGE=BEFORE_WRITE parsed_value=%s',
                $callId,
                $fileName,
                (string) ($scorePayload->isBookedValue() ?? 'NULL')
            ),
            true
        );
        $bitrixResult = $writer->write($callId, $scorePayload);
    } else {
        $bitrixError = 'Processing dependencies are unavailable; payload stored only.';
        appendIntegrationLog(
            $integrationLogPath,
            sprintf(
                'CALL_ID=%s FILE=%s BITRIX_WRITE_SKIPPED reason=%s',
                $callId,
                $fileName,
                $bitrixError
            )
        );
    }
} catch (Throwable $e) {
    $bitrixError = $e->getMessage();
    appendIntegrationLog(
        $integrationLogPath,
        sprintf(
            'CALL_ID=%s FILE=%s BITRIX_WRITE_ERROR=%s WARNINGS=%s',
            $callId,
            $fileName,
            $bitrixError,
            $scorePayload !== null ? implode(' | ', $scorePayload->warnings()) : ''
        )
    );

    if ($failFast) {
        respond(500, [
            'ok' => false,
            'error' => 'Bitrix write failed.',
            'details' => $bitrixError,
            'call_id' => $callId,
            'file' => $fileName,
        ]);
    }
}

if ($bitrixResult !== null) {
    appendIntegrationLog(
        $integrationLogPath,
        sprintf(
            'CALL_ID=%s FILE=%s BITRIX_WRITE_OK element_id=%s verified=%s',
            $callId,
            $fileName,
            (string) ($bitrixResult['element_id'] ?? ''),
            isset($bitrixResult['verified']) && $bitrixResult['verified'] ? 'Y' : 'N'
        )
    );
} elseif ($bitrixError !== null && $bitrixError !== '') {
    appendIntegrationLog(
        $integrationLogPath,
        sprintf(
            'CALL_ID=%s FILE=%s BITRIX_WRITE_NOT_DONE reason=%s',
            $callId,
            $fileName,
            $bitrixError
        )
    );
}

/** @var array<string, mixed> $responseBody */
$responseBody = [
    'ok' => true,
    'call_id' => $callId,
    'file' => $fileName,
    'bytes_written' => $bytes,
    'processing' => [
        'deps_loaded' => $processingDependenciesLoaded,
        'parsed' => $scorePayload !== null,
        'bitrix_written' => $bitrixResult !== null,
        'bitrix_error' => $bitrixError,
    ],
];

if ($verboseResponse) {
    $responseBody['scores'] = [
        'criteria_scores' => $scorePayload !== null ? $scorePayload->criteriaScores() : [],
        'base_score' => $scorePayload !== null ? $scorePayload->baseScore() : null,
        'final_score' => $scorePayload !== null ? $scorePayload->finalScore() : null,
        'deduction_total' => $scorePayload !== null ? $scorePayload->deductionTotal() : null,
        'criteria_total' => $scorePayload !== null ? $scorePayload->criteriaTotal() : 0,
        'final_score_percent' => $scorePayload !== null ? $scorePayload->finalScorePercent() : null,
        'is_booked_value' => $scorePayload !== null ? $scorePayload->isBookedValue() : null,
        'warnings' => $scorePayload !== null ? $scorePayload->warnings() : ['processing skipped: dependencies unavailable'],
    ];
    $responseBody['bitrix'] = [
        'written' => $bitrixResult !== null,
        'element_id' => $bitrixResult['element_id'] ?? null,
        'verified' => $bitrixResult['verified'] ?? null,
        'error' => $bitrixError,
        'fail_fast' => $failFast,
        'write_logs' => (bool) ($scoreConfig['write_logs'] ?? true),
    ];
}

if (
    $deleteProcessedFiles
    && $bitrixResult !== null
    && isset($bitrixResult['verified'])
    && $bitrixResult['verified'] === true
) {
    if (!@unlink($filePath)) {
        appendIntegrationLog(
            $integrationLogPath,
            sprintf('CALL_ID=%s FILE=%s DELETE_ERROR=Unable to delete processed payload file.', $callId, $fileName)
        );
    } elseif ($verboseResponse) {
        $responseBody['file_deleted'] = true;
    }
}

respond(200, $responseBody);

