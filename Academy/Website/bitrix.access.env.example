BITRIX_BOX_HANDLER_PATH="/local/akademia-profi/academyprofi-catalog-app/handler.php"

BITRIX_APP_CLIENT_ID="local.xxxxx"
BITRIX_APP_CLIENT_SECRET="xxxxx"

